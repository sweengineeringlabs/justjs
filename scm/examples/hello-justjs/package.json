{
  "name": "hello-justjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Demo app showing JustJS data flow through 4 OSI layers + AOP aspects",
  "scripts": {
    "codegen": "bun run scripts/codegen.js",
    "dev": "bun run codegen && vite",
    "build": "bun run codegen && vite build",
    "preview": "vite preview",
    "typecheck": "bun run codegen && tsc --noEmit"
  },
  "dependencies": {
    "@justjs/application": "^0.1.0",
    "@justjs/aop-security": "^0.1.0",
    "@justjs/aop-observability": "^0.1.0",
    "@justjs/aop-i18n": "^0.1.0",
    "@justjs/aop-flags": "^0.1.0",
    "@justjs/aop-analytics": "^0.1.0",
    "@justjs/aop-theming": "^0.1.0"
  },
  "devDependencies": {
    "@justjs/vite": "^0.1.0",
    "vite": "^5.0.0",
    "typescript": "^5.5.0"
  }
}
