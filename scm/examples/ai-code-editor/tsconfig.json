{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@browser/*": ["./src/shared/browser-sdk/*"]
    }
  },
  "include": ["src"],
  "exclude": ["**/*_test.ts"]
}
