{
  "name": "justjs",
  "private": true,
  "version": "0.1.0",
  "description": "JustJS — the UI domain layer",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build":     "bun run --filter '*' build",
    "test":      "bun run --filter '*' test",
    "lint":      "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "engines": {
    "bun": ">=1.0"
  },
  "packageManager": "bun@1.3.5"
}
